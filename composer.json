{
    "name": "wotz/filament-resource-picker",
    "description": "This is my package filament-resource-picker",
    "keywords": [
        "who owns the zebra",
        "laravel",
        "filament-resource-picker"
    ],
    "homepage": "https://github.com/wotzebra/filament-resource-picker",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^12.0|^13.0",
        "livewire/livewire": "^4.0",
        "spatie/laravel-package-tools": "^1.12"
    },
    "require-dev": {
        "larastan/larastan": "^2.0|^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0|^9.0",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "phpstan/extension-installer": "^1.1|^2.0",
        "phpstan/phpstan-deprecation-rules": "^1.0|^2.0",
        "phpstan/phpstan-phpunit": "^1.0|^2.0"
    },
    "autoload": {
        "psr-4": {
            "Wotz\\FilamentResourcePicker\\": "src",
            "Wotz\\FilamentResourcePicker\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wotz\\FilamentResourcePicker\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Wotz\\FilamentResourcePicker\\Providers\\FilamentResourcePickerServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
